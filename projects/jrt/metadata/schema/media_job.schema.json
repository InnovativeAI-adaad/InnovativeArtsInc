{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "projects/jrt/metadata/schema/media_job.schema.json",
  "title": "Media Job",
  "description": "Schema for autonomous media processing job records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "track_id",
    "stage",
    "input_assets",
    "output_assets",
    "agent_owner",
    "status",
    "attempt",
    "created_at",
    "provenance_refs"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "Unique ID for this autonomous job run.",
      "minLength": 1
    },
    "track_id": {
      "type": "string",
      "description": "Canonical track identifier associated with the job.",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "description": "Workflow stage at which this job record is emitted.",
      "minLength": 1
    },
    "input_assets": {
      "type": "array",
      "description": "Source assets consumed by this run.",
      "items": {
        "$ref": "#/$defs/assetRef"
      },
      "minItems": 1
    },
    "output_assets": {
      "type": "array",
      "description": "Assets produced by this run.",
      "items": {
        "$ref": "#/$defs/assetRef"
      },
      "minItems": 1
    },
    "agent_owner": {
      "type": "string",
      "description": "Agent responsible for this run.",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "description": "Terminal status for this run.",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "blocked"
      ]
    },
    "attempt": {
      "type": "integer",
      "description": "Attempt number for retries on the same job.",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "description": "UTC timestamp when job record was created.",
      "format": "date-time"
    },
    "provenance_refs": {
      "type": "array",
      "description": "References to provenance records generated/used by this run.",
      "items": {
        "$ref": "#/$defs/provenanceRef"
      },
      "minItems": 1
    },
    "generation_config": {
      "type": "object",
      "description": "Generation-time model and prompt controls used to create media outputs. Canonical field names use snake_case; legacy names are accepted during migration.",
      "additionalProperties": false,
      "properties": {
        "model_version": {
          "type": "string",
          "minLength": 1
        },
        "prompt_template_version": {
          "type": "string",
          "minLength": 1
        },
        "random_seed": {
          "description": "Seed value used for reproducible generation.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "creativity_profile": {
          "description": "Creativity profile label or structured profile payload used for generation.",
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "conservative",
                "balanced",
                "exploratory"
              ]
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "temperature": {
                  "type": "number",
                  "minimum": 0
                },
                "top_p": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          ]
        },
        "style_constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "style_dna_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "model_id": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "description": "Legacy seed key accepted during migration.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        }
      },
      "oneOf": [
        {
          "title": "canonical_generation_config",
          "required": [
            "model_version",
            "prompt_template_version",
            "random_seed",
            "creativity_profile",
            "style_constraints",
            "style_dna_fingerprint"
          ]
        },
        {
          "title": "legacy_generation_config",
          "required": [
            "model_id",
            "prompt_template_version",
            "seed",
            "creativity_profile",
            "style_constraints"
          ]
        }
      ]
    },
    "uniqueness_report": {
      "type": "object",
      "description": "Novelty/similarity evaluation output used to gate publication. Canonical field names use snake_case; legacy names are accepted during migration.",
      "additionalProperties": false,
      "properties": {
        "novelty_index": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "similarity_method": {
          "type": "string",
          "minLength": 1
        },
        "max_similarity_observed": {
          "type": "number",
          "minimum": 0
        },
        "similarity_guardrail_pass": {
          "type": "boolean"
        },
        "novelty_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "pass",
            "revise",
            "block"
          ]
        }
      },
      "oneOf": [
        {
          "title": "canonical_uniqueness_report",
          "required": [
            "novelty_index",
            "similarity_method",
            "max_similarity_observed",
            "similarity_guardrail_pass"
          ]
        },
        {
          "title": "legacy_uniqueness_report",
          "required": [
            "novelty_score",
            "similarity_method",
            "max_similarity_observed",
            "decision"
          ]
        }
      ]
    },
    "trinity_of_the_dirt": {
      "type": "object",
      "description": "Creative intent snapshot that records lyric/source context, emotional target, and production palette constraints.",
      "additionalProperties": false,
      "required": [
        "red_couch",
        "red_crosses",
        "red_dirt"
      ],
      "properties": {
        "red_couch": {
          "type": "string",
          "description": "Lyrics/source descriptor anchoring the narrative and provenance context.",
          "minLength": 1
        },
        "red_crosses": {
          "type": "object",
          "description": "Emotion and spiritual intensity calibration for the track.",
          "additionalProperties": false,
          "required": [
            "intensity_score",
            "notes"
          ],
          "properties": {
            "intensity_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Normalized emotion/spiritual intensity target from 0.0 to 1.0."
            },
            "notes": {
              "type": "string",
              "minLength": 1,
              "description": "Human-readable context for how the intensity target should be interpreted."
            }
          }
        },
        "red_dirt": {
          "type": "array",
          "description": "Production palette descriptors that define the sonic texture.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "audio_fidelity_verification": {
      "type": "object",
      "description": "Audio QA verification block for technical quality and creative alignment.",
      "additionalProperties": false,
      "required": [
        "clipping_check",
        "stereo_width_check",
        "vibe_alignment_check",
        "verified_at"
      ],
      "properties": {
        "clipping_check": {
          "$ref": "#/$defs/fidelityMetricCheck"
        },
        "stereo_width_check": {
          "$ref": "#/$defs/fidelityMetricCheck"
        },
        "vibe_alignment_check": {
          "$ref": "#/$defs/fidelityVibeCheck"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time",
          "description": "UTC timestamp when fidelity verification was completed."
        }
      }
    },
    "ip_sign_off": {
      "type": "object",
      "description": "IP review and publication sign-off metadata.",
      "additionalProperties": false,
      "required": [
        "status",
        "signed_off_by",
        "signed_off_at"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "approved",
            "rejected"
          ]
        },
        "signed_off_by": {
          "type": "string",
          "minLength": 1
        },
        "signed_off_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "stage": {
            "type": "string",
            "pattern": "^(generation($|/)|mix($|/)|master($|/)|rollout($|/)|publish($|/)|distribution($|/)|release($|/))"
          }
        },
        "required": [
          "stage"
        ]
      },
      "then": {
        "required": [
          "generation_config",
          "uniqueness_report"
        ]
      }
    },
    {
      "if": {
        "required": [
          "ip_sign_off"
        ]
      },
      "then": {
        "required": [
          "audio_fidelity_verification"
        ],
        "properties": {
          "audio_fidelity_verification": {
            "type": "object",
            "required": [
              "clipping_check",
              "stereo_width_check",
              "vibe_alignment_check"
            ],
            "properties": {
              "clipping_check": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "const": "pass"
                  }
                }
              },
              "stereo_width_check": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "const": "pass"
                  }
                }
              },
              "vibe_alignment_check": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "const": "pass"
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "assetRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "path"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "mime_type": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenanceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_type",
        "ref_id"
      ],
      "properties": {
        "ref_type": {
          "type": "string",
          "minLength": 1
        },
        "ref_id": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fidelityMetricCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "metrics"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "metrics": {
          "type": "object",
          "description": "Measured values used to evaluate this check.",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "fidelityVibeCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "rationale"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "metrics": {
          "type": "object",
          "description": "Optional quantified support signals for vibe alignment.",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    }
  }
}
