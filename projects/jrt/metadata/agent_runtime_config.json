{
  "retry_policy": {
    "max_attempts": 3,
    "backoff_seconds": [1, 3, 8]
  },
  "failure_classes": {
    "transient": [
      "RetryableAgentError",
      "TimeoutError",
      "ConnectionError",
      "OSError"
    ],
    "deterministic": [
      "DeterministicAgentError",
      "ValueError",
      "TypeError",
      "FileNotFoundError",
      "AssertionError"
    ]
  }
}
