# InnovativeArtsInc runtime configuration example.
# Copy to .env for local runs. Keep real values out of git and secret scanners.

# Agent runtime gate. Set to false to halt autonomous production runs.
AGENT_ENABLED=true

# Provider credentials (required only for workflows that call the provider).
# Never commit real keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
SUNO_API_KEY=
REPLICATE_API_TOKEN=
GITHUB_TOKEN=

# Governance/audit validation.
AGENT_LOG_HMAC_KEY=

# Autonomous media CLI defaults.
IAI_REPO_ROOT=.
IAI_MEDIA_JOB_ID=prod-job-001
IAI_MEDIA_TRACK_ID=track-001
IAI_MEDIA_ACTOR=media-conductor
IAI_AGENT_OWNER=MediaAgent
IAI_MEDIA_ATTEMPT=1

# Optional JSON arrays or paths to JSON files consumed by autonomous-media.
IAI_INPUT_ASSETS_JSON=
IAI_OUTPUT_ASSETS_JSON=
IAI_PROVENANCE_REFS_JSON=

# Runtime mode labels for external orchestrators/logging.
IAI_RUNTIME_ENV=development
IAI_LOG_LEVEL=INFO
